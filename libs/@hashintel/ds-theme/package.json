{
  "name": "@hashintel/ds-theme",
  "version": "0.1.2",
  "description": "HASH PandaCSS Preset",
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "https://github.com/hashintel/hash.git",
    "directory": "libs/@hashintel/ds-theme"
  },
  "files": [
    "CHANGELOG.md",
    "dist",
    "LICENSE",
    "LICENSE-APACHE.md",
    "LICENSE-MIT.md",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/main.js",
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "default": "./dist/theme.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "fix": "npm-run-all --continue-on-error \"fix:*\"",
    "fix:format": "biome format --write",
    "lint": "npm-run-all --continue-on-error \"lint:*\"",
    "lint:tsc": "tsc --noEmit",
    "prepublishOnly": "turbo run build"
  },
  "dependencies": {
    "@hashintel/ds-components": "workspace:^"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "npm-run-all": "4.1.5",
    "tsdown": "^0.21.4",
    "typescript": "5.9.3"
  }
}
