{
  "name": "@hashintel/petrinaut",
  "version": "0.0.12",
  "description": "A visual editor for Petri nets",
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hashintel/hash.git",
    "directory": "libs/@hashintel/petrinaut"
