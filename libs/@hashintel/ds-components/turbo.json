{
  "$schema": "https://turborepo.org/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "codegen": {
      "outputs": ["src/preset/theme/*.gen.ts", "../ds-helpers/styled-system/**"]
    },
    "build:ladle": {
      "dependsOn": ["^build"],
      "outputs": [
        ".build/ladle/**",
        "src/preset/theme/*.gen.ts",
        "../ds-helpers/styled-system/**"
      ]
    },
    "storybook": {
      "cache": false,
      "dependsOn": ["codegen", "^build"],
      "persistent": true
    },
    "storybook:build": {
      "dependsOn": ["codegen", "^build"],
      "outputs": ["storybook-static/**"]
    }
  }
}
