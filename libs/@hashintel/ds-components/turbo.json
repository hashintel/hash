{
  "$schema": "https://turborepo.org/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "codegen": {
      "dependsOn": [],
      "outputs": [
        "src/preset/theme/**/*.gen.ts",
        "../ds-helpers/styled-system/**"
      ]
    },
    "codegen:ladle": {
      "dependsOn": [],
      "outputs": [
        "src/preset/theme/**/*.gen.ts",
        "../ds-helpers/styled-system/**"
      ]
    },
    "build:ladle": {
      "dependsOn": ["@hashintel/refractive#build"],
      "outputs": [
        ".build/ladle/**",
        "src/preset/theme/**/*.gen.ts",
        "../ds-helpers/styled-system/**"
      ]
    },
    "dev": {
      "cache": false,
      "dependsOn": ["@hashintel/refractive#build"],
      "persistent": true
    },
    "dev:storybook": {
      "cache": false,
      "dependsOn": ["codegen", "@hashintel/refractive#build"],
      "persistent": true
    },
    "build:storybook": {
      "dependsOn": ["codegen", "@hashintel/refractive#build"],
      "outputs": ["storybook-static/**"]
    }
  }
}
