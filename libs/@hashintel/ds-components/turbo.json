{
  "$schema": "https://turborepo.org/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "build:buildinfo": {
      "dependsOn": ["codegen"],
      "outputs": ["dist/panda.buildinfo.json"]
    },
    "build:ladle": {
      "dependsOn": ["codegen", "@hashintel/refractive#build"],
      "outputs": [".build/ladle/**"]
    },
    "build:lib": {
      "dependsOn": ["codegen"],
      "outputs": ["dist/**"]
    },
    "codegen": {
      "dependsOn": [],
      "outputs": [
        "src/preset/theme/**/*.gen.ts",
        "../ds-helpers/styled-system/**"
      ]
    },
    "dev": {
      "cache": false,
      "dependsOn": ["codegen", "@hashintel/refractive#build"],
      "persistent": true
    },
    "lint:eslint": {
      "dependsOn": [
        "codegen",
        "@local/eslint#build",
        "@hashintel/refractive#build"
      ],
      "env": ["CHECK_TEMPORARILY_DISABLED_RULES"]
    },
    "lint:tsc": {
      "dependsOn": ["codegen", "@hashintel/refractive#build"]
    },
    "dev:ladle": {
      "cache": false,
      "dependsOn": ["codegen", "@hashintel/refractive#build"],
      "persistent": true
    },
    "preview:ladle": {
      "dependsOn": ["build:ladle"]
    },
    "test:unit": {
      "dependsOn": ["build:buildinfo"],
      "env": ["TEST_COVERAGE"]
    },
    "test:snapshots": {
      "dependsOn": ["build:ladle"]
    },
    "test:snapshots:update": {
      "dependsOn": ["build:ladle"]
    }
  }
}
