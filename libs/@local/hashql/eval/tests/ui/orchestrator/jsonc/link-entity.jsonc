// Select the friend-of link entity by UUID. Verifies PartialLinkData
// hydration from real LEFT JOIN columns: entity IDs, confidence, provenance.
// biome-ignore format: readability
["::graph::tail::collect",
  ["::graph::body::filter",
    ["::graph::head::entities", ["input", "temporal_axes", "_"]],
    ["fn", { "#tuple": [] }, { "#struct": { "vertex": "_" } }, "_",
      ["==",
        "vertex.metadata.record_id.entity_id.entity_uuid",
        ["input", "friend_link_uuid", "::graph::types::knowledge::entity::EntityUuid"]
      ]
    ]
  ]
]
