// Filter with literal equality: true == true. All entities pass.
// biome-ignore format: readability
["::graph::tail::collect",
  ["::graph::body::filter",
    ["::graph::head::entities", ["input", "temporal_axes", "_"]],
    ["fn", { "#tuple": [] }, { "#struct": { "vertex": "_" } }, "_",
      ["==", {"#literal": true}, {"#literal": true}]
    ]
  ]
]
