//@ run: pass
//@ description: Struct aggregate from entity fields - AggregateKind::Struct → jsonb_build_object
// biome-ignore format: readability
["::graph::tail::collect",
  ["::graph::body::filter",
    ["::graph::head::entities", ["input", "time_axis", "_"]],
    ["fn", { "#tuple": [] }, { "#struct": { "vertex": "_" } }, "_",
      ["==",
        { "#struct": {
          "uuid": "vertex.metadata.record_id.entity_id.entity_uuid",
          "web": "vertex.metadata.record_id.entity_id.web_id"
        }},
        { "#struct": {
          "uuid": ["input", "u", "::graph::types::knowledge::entity::EntityUuid"],
          "web": ["input", "w", "::graph::types::principal::actor_group::web::WebId"]
        }}
      ]
    ]
  ]
]
