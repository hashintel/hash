//@ run: pass
//@ description: Short-circuit AND on inputs - && desugars to if/else, survives as CASE WHEN
// biome-ignore format: readability
["::graph::tail::collect",
  ["::graph::body::filter",
    ["::graph::head::entities", ["input", "time_axis", "_"]],
    ["fn", { "#tuple": [] }, { "#struct": { "vertex": "_" } }, "_",
      ["&&",
        ["input", "a", "Boolean"],
        ["input", "b", "Boolean"]
      ]
    ]
  ]
]
