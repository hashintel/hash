//@ run: pass
//@ description: Only base table fields accessed - no unnecessary joins in FROM clause
// biome-ignore format: readability
["::graph::tail::collect",
  ["::graph::body::filter",
    ["::graph::head::entities", ["input", "time_axis", "_"]],
    ["fn", { "#tuple": [] }, { "#struct": { "vertex": "_" } }, "_",
      ["==",
        "vertex.metadata.record_id.entity_id.web_id",
        ["input", "expected_web", "::graph::types::principal::actor_group::web::WebId"]
      ]
    ]
  ]
]
