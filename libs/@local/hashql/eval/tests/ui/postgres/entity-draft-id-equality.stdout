════ SQL ═══════════════════════════════════════════════════════════════════════

SELECT "entity_temporal_metadata_0_0_0"."draft_id" AS "draft_id"
FROM "entity_temporal_metadata" AS "entity_temporal_metadata_0_0_0"
WHERE "entity_temporal_metadata_0_0_0"."transaction_time" && $0 AND "entity_temporal_metadata_0_0_0"."decision_time" && $1

════ Parameters ════════════════════════════════════════════════════════════════

$0: TemporalAxis(Transaction)
$1: TemporalAxis(Decision)
