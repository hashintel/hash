fn {graph::read::filter@4294967040}(%0: (), %1: Entity) -> Boolean {
    let %2: ?
    let %3: ?
    let %4: Boolean

    bb0(): {
        %2 = %1.properties.name
        %3 = input LOAD expected
        %4 = %2 == %3

        return %4
