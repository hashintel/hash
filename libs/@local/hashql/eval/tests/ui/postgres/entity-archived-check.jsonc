//@ run: pass
//@ description: Entity archived filter - entity_editions join triggered by metadata.archived access
// prettier-ignore
["::graph::tail::collect",
  ["::graph::body::filter",
    ["::graph::head::entities", ["input", "time_axis", "_"]],
    ["fn", { "#tuple": [] }, { "#struct": { "vertex": "_" } }, "_",
      ["==",
        "vertex.metadata.archived",
        { "#literal": false }
      ]
    ]
  ]
]
