════ Initial HIR ═══════════════════════════════════════════════════════════════

let foo:0 = <?30>(a:0: ?30): ?30 -> a:0,
    bar:0 = <?32>(a:1: ?32): ?32 -> foo:0(a:1)
in
bar:0(2)

════ HIR after type checking ═══════════════════════════════════════════════════

let foo:0 = <?33>(a:0: ?33): ?33 -> a:0,
    bar:0 = <?35>(a:1: ?35): ?35 -> foo:0(a:1)
in
bar:0(2)

════ Types ═════════════════════════════════════════════════════════════════════

┌─ let foo:0 = <?33>(a:0: ?33): ?33 -> a:0,
│      bar:0 = <?35>(a:1: ?35): ?35 -> foo:0(a:1)
│  in
│  bar:0(2)
└→ Integer

┌─ <?33>(a:0: ?33): ?33 -> a:0
└→ <T:0?33>(T:0?33) -> T:0?33

┌─ a:0
└→ ?

┌─ <?35>(a:1: ?35): ?35 -> foo:0(a:1)
└→ <T:1?35>(T:1?35) -> T:1?35

┌─ foo:0(a:1)
└→ ?

┌─ foo:0
└→ (?) -> ?

┌─ a:1
└→ ?

┌─ bar:0(2)
└→ Integer

┌─ bar:0
└→ (Integer) -> Integer

┌─ 2
└→ Integer

