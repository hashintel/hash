┌─ let foo:0 = <?33>(a:0: ?33): ?33 -> a:0,
│      bar:0 = <?35>(a:1: ?35): ?35 -> foo:0(a:1)
│  in
│  bar:0(2)
└→ _1«Integer»

┌─ <?33>(a:0: ?33): ?33 -> a:0
└→ <T:0?33>(T:0?33) -> T:0?33

┌─ a:0
└→ ?30«?»

┌─ <?35>(a:1: ?35): ?35 -> foo:0(a:1)
└→ <T:1?35>(T:1?35) -> T:1?35

┌─ foo:0(a:1)
└→ _0«?»

┌─ foo:0
└→ <T:0?34>(T:0?34«?») -> T:0?34«?»

┌─ a:1
└→ ?32«?»

┌─ bar:0(2)
└→ _1«Integer»

┌─ bar:0
└→ <T:1?36>(T:1?36«Integer») -> T:1?36«Integer»

