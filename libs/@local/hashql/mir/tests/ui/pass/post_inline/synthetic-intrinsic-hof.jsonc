//@ run: pass
//@ description: Higher-order function receiving an intrinsic as a value
// The intrinsic `<=` is passed as a value to `apply`. After all optimizations,
// the synthetic wrapper should be inlined and the comparison exposed directly.
[
  "let",
  "apply",
  [
    "fn",
    { "#tuple": [] },
    { "#struct": { "a": "Integer", "b": "Integer", "f": "_" } },
    "_",
    ["f", "a", "b"]
  ],
  ["apply", { "#literal": 2 }, { "#literal": 3 }, "<="]
]
